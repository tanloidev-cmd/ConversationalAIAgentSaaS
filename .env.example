# Application
NODE_ENV=development
APP_VERSION=0.1.0
ENVIRONMENT=dev
LOG_LEVEL=debug
OTEL_ENABLED=false

# Local API
API_PORT=3001

# PostgreSQL (docker compose)
DATABASE_URL=postgresql://conversational:conversational@localhost:5432/conversational_ai

# DynamoDB Local
DYNAMODB_ENDPOINT=http://localhost:8000
SESSIONS_TABLE_NAME=conversational-ai-sessions
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Local API dev auth (never enable in production)
DEV_AUTH_BYPASS=true
DEV_TENANT_ID=tenant-dev
DEV_USER_ID=user-dev
BEDROCK_MOCK=true
BEDROCK_MODEL_ID_LIGHT=amazon.nova-micro-v1:0
BEDROCK_MODEL_ID_REASONING=anthropic.claude-3-5-haiku-20241022-v1:0

# Step Functions (set after Terraform apply)
# AGENT_STATE_MACHINE_ARN=

# Cognito (fill after Terraform apply — see docs/runbooks/phase1-deploy-handoff.md)
NEXT_PUBLIC_COGNITO_DOMAIN=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_REDIRECT_URI=http://localhost:3000/callback
NEXT_PUBLIC_APP_URL=http://localhost:3000
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_ISSUER=

# API (local dev server or API Gateway URL after deploy)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Observability
SENTRY_DSN=

# Terraform / CI (not used locally unless deploying)
# TERRAFORM_STATE_BUCKET=
# AWS_ROLE_ARN=
