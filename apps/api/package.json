    "@conversational-ai/observability": "workspace:*",
    "@conversational-ai/session-store": "workspace:*",
    "@conversational-ai/shared": "workspace:*",
    "@conversational-ai/tool-registry": "workspace:*",
    "@sentry/aws-serverless": "^8.47.0",
    "dotenv": "^16.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.146",
    "@types/node": "^22.10.2",
    "esbuild": "^0.24.2",
